            "body": {
              "mode": "raw",
              "raw": "{\n  \"clienteId\": 2,\n  \"mascotaId\": 1,\n  \"veterinarioId\": 4,\n  \"boxId\": 1,\n  \"sucursal\": \"Chillán\",\n  \"servicio\": \"Consulta general\",\n  \"fechaHora\": \"2025-12-15\",\n  \"duracionMin\": 30,\n  \"estado\": \"RESERVADA\",\n  \"canal\": \"WEB\"\n}"
            }
          }
        },
        {
          "name": "Ficha Clínica: listar fichas",
